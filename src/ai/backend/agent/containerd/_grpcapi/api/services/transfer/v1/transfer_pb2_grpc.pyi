"""Type stub for a protoc-generated module.

The generated ``*_pb2.py`` files build their message classes at import time (protobuf's
``_builder``), so there is nothing static for a type checker to see and every symbol read from them
("mount_pb2.Mount", "tasks_pb2.StartRequest", ...) is reported as a missing attribute. The
generated ``*_pb2_grpc.py`` stubs are likewise unannotated, so calling them trips no-untyped-call.

Declaring the module's attributes as dynamic is the accurate description of what these modules are:
their contents genuinely are constructed at runtime. Proper message types would need .pyi files
generated by mypy-protobuf as part of the protoc run that produced these files; this file records
what we actually know until then.
"""

from typing import Any

def __getattr__(name: str) -> Any: ...
