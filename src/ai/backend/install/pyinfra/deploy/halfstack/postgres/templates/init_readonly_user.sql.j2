-- Create database conditionally using \gexec
SELECT 'CREATE DATABASE {{ fasttrack_config.postgres_db }} OWNER {{ fasttrack_config.postgres_user }}'
WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = '{{ fasttrack_config.postgres_db }}')\gexec

\c {{ fasttrack_config.postgres_db }}

GRANT ALL ON SCHEMA public TO {{ fasttrack_config.postgres_user }};

-- Grant read-only access to monitoring user
GRANT CONNECT ON DATABASE {{ fasttrack_config.postgres_db }} TO {{ postgres_readonly_user }};
GRANT USAGE ON SCHEMA public TO {{ postgres_readonly_user }};
GRANT SELECT ON ALL TABLES IN SCHEMA public TO {{ postgres_readonly_user }};
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO {{ postgres_readonly_user }};
{%- endif %}
