#!/bin/bash
set -euo pipefail

BACKUP_DIR="$(dirname "$0")/backups"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BACKUP_FILE="${BACKUP_DIR}/postgres_ha_backup_${TIMESTAMP}.dump"
CONTAINER_NAME="{{ config.container_name_prefix }}-{{ pg_cluster_info.node_name }}"
DB_USER="{{ config.pg_superuser_id }}"
API_PORT="{{ pg_cluster_info.pg_api_port }}"

echo "=== PostgreSQL HA Cluster Backup ==="
echo "Node: {{ pg_cluster_info.node_name }}"
echo "Container: ${CONTAINER_NAME}"
echo ""

# Check if container is running
if ! docker ps --format "table {{ '{{.Names}}' }}" | grep -q "^${CONTAINER_NAME}$"; then
    echo "Error: PostgreSQL container '${CONTAINER_NAME}' is not running"
    exit 1
fi

# Check Patroni cluster status
echo "Checking cluster status..."
STATUS=$(curl -s http://127.0.0.1:${API_PORT}/ 2>/dev/null)
ROLE=$(echo "$STATUS" | jq -r '.role // "unknown"')
STATE=$(echo "$STATUS" | jq -r '.state // "unknown"')

echo "Current node role: ${ROLE}"
echo "Current node state: ${STATE}"
echo ""

if [ "$STATE" != "running" ]; then
    echo "Warning: Node state is '${STATE}', not 'running'"
    echo "Backup may fail or be inconsistent"
    read -p "Continue anyway? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Backup cancelled."
        exit 0
    fi
fi

# Create backup directory
mkdir -p "${BACKUP_DIR}"

# Perform backup
echo "Starting full cluster backup..."
echo "Note: This creates a logical backup of all databases using pg_dumpall"
echo ""

docker exec "${CONTAINER_NAME}" pg_dumpall -U "${DB_USER}" > "${BACKUP_FILE}"
gzip "${BACKUP_FILE}"

echo ""
echo "Full backup completed successfully!"
echo "Backup file: ${BACKUP_FILE}.gz"
echo "Backup size: $(du -h "${BACKUP_FILE}.gz" | cut -f1)"
echo ""

# Cleanup old backups
echo "Cleaning up old backups (keeping last 7)..."
find "${BACKUP_DIR}" -name "postgres_ha_backup_*.dump.gz" -type f | sort -r | tail -n +8 | xargs -r rm -f

echo ""
echo "Backup process completed!"
echo ""
echo "Available backups:"
find "${BACKUP_DIR}" -name "postgres_ha_backup_*.dump.gz" -type f | sort -r | head -5
