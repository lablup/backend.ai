#!/bin/bash
set -euo pipefail

BACKUP_DIR="{{ service_dir }}/backups"
CONTAINER_NAME="{{ config.container_name_prefix }}-{{ etcd_cluster_info.node_name }}"
DATA_DIR="{{ data_dir }}"
ENV_FILE="{{ service_dir }}/.env"
NODE_NAME="{{ etcd_cluster_info.node_name }}"

# Load environment variables from .env file
if [ ! -f "${ENV_FILE}" ]; then
    echo "Error: Environment file not found: ${ENV_FILE}"
    exit 1
fi
set -a
source "${ENV_FILE}"
set +a

show_usage() {
    echo "Usage: $0 <backup_file>"
    echo ""
    echo "Available backup files:"
    find "${BACKUP_DIR}" -name "etcd_snapshot_*.db.gz" -type f | sort -r | head -10
    echo ""
    echo "IMPORTANT: ETCD Cluster Restore Procedure"
    echo "=========================================="
    echo "This node is part of a multi-node ETCD cluster for Backend.AI."
    echo ""
    echo "To restore the cluster properly:"
    echo "1. Stop ALL etcd containers on ALL nodes"
    echo "2. Run this restore script on EACH node with the SAME backup file"
    echo "3. Start etcd containers on ALL nodes simultaneously"
    echo ""
    echo "Current node: ${NODE_NAME}"
    echo "Cluster name: ${ETCD_CLUSTER_NAME}"
    exit 1
}

if [ $# -eq 0 ]; then
    show_usage
fi

BACKUP_FILE="$1"
if [ ! -f "$BACKUP_FILE" ]; then
    echo "Error: Backup file '$BACKUP_FILE' not found"
    show_usage
fi

# Build initial cluster string from environment variables
INITIAL_CLUSTER=""
{% for node in etcd_nodes -%}
ETCD_NODE{{ node.node_number }}_PEER_URL="http://etcd{{ node.node_number }}:${ETCD{{ node.node_number }}_PEER_PORT}"
{% if loop.first -%}
INITIAL_CLUSTER="etcd{{ node.node_number }}=${ETCD_NODE{{ node.node_number }}_PEER_URL}"
{% else -%}
INITIAL_CLUSTER="${INITIAL_CLUSTER},etcd{{ node.node_number }}=${ETCD_NODE{{ node.node_number }}_PEER_URL}"
{% endif -%}
{% endfor %}

INITIAL_ADVERTISE_PEER_URLS="http://${THIS_ETCD_NODE_NAME}:${THIS_HOST_ETCD_PEER_PORT}"

echo "==============================================="
echo "ETCD HA Cluster Restore - Node: ${NODE_NAME}"
echo "==============================================="
echo ""
echo "Backup file: $BACKUP_FILE"
echo "Container: $CONTAINER_NAME"
echo "Data directory: $DATA_DIR"
echo ""

# Check if container is running
if docker ps --format "table {{ '{{.Names}}' }}" | grep -q "^${CONTAINER_NAME}$"; then
    echo "Warning: etcd container '${CONTAINER_NAME}' is currently running"
    echo "The container will be stopped for restore operation."
    echo ""
    read -p "Continue? (yes/no): " confirm
    if [ "$confirm" != "yes" ]; then
        echo "Restore cancelled."
        exit 0
    fi
    echo "Stopping etcd container..."
    docker stop "${CONTAINER_NAME}" || true
fi

echo ""
echo "=========================================="
echo "CRITICAL WARNING: ETCD Cluster Restore"
echo "=========================================="
echo ""
echo "This will COMPLETELY REPLACE the current etcd data on node '${NODE_NAME}'!"
echo ""
echo "For proper ETCD cluster recovery, you MUST:"
echo "1. Ensure ALL cluster nodes are stopped"
echo "2. Run this restore on ALL nodes with the SAME backup file"
echo "3. Start ALL nodes together after restore completes"
echo ""
echo "Current cluster configuration:"
echo "  Node name: ${THIS_ETCD_NODE_NAME}"
echo "  Cluster name: ${ETCD_CLUSTER_NAME}"
echo "  Cluster members: ${INITIAL_CLUSTER}"
echo "  Peer URLs: ${INITIAL_ADVERTISE_PEER_URLS}"
echo ""
echo "Type 'restore-${NODE_NAME}' to confirm:"
read -p "> " confirm
if [ "$confirm" != "restore-${NODE_NAME}" ]; then
    echo "Restore cancelled."
    exit 0
fi

# Extract backup file to mounted backups directory
SNAPSHOT_FILE="${BACKUP_DIR}/temp_restore_snapshot.db"
echo ""
echo "Extracting backup file..."
if [[ "$BACKUP_FILE" =~ \.gz$ ]]; then
    zcat "$BACKUP_FILE" > "${SNAPSHOT_FILE}"
else
    cp "$BACKUP_FILE" "${SNAPSHOT_FILE}"
fi

# Backup current data directory
if [ -d "${DATA_DIR}" ]; then
    echo "Backing up current data directory..."
    BACKUP_TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    mv "${DATA_DIR}" "${DATA_DIR}.backup.${BACKUP_TIMESTAMP}"
    echo "Old data backed up to: ${DATA_DIR}.backup.${BACKUP_TIMESTAMP}"
fi

# Restore from snapshot using cluster configuration from .env
echo "Restoring from snapshot for node '${THIS_ETCD_NODE_NAME}'..."
mkdir -p "${DATA_DIR}"

docker run --rm \
    -v "${BACKUP_DIR}:/backups:ro" \
    -v "${DATA_DIR}:/etcd-data:rw" \
    {{ config.container_image }} \
    etcdctl snapshot restore /backups/temp_restore_snapshot.db \
        --data-dir /etcd-data \
        --name "${THIS_ETCD_NODE_NAME}" \
        --initial-cluster "${INITIAL_CLUSTER}" \
        --initial-cluster-token "${INITIAL_ETCD_CLUSTER_TOKEN}" \
        --initial-advertise-peer-urls "${INITIAL_ADVERTISE_PEER_URLS}"

# Clean up temporary snapshot file
rm -f "${SNAPSHOT_FILE}"

echo ""
echo "========================================"
echo "Restore completed on node: ${NODE_NAME}"
echo "========================================"
echo ""
echo "NEXT STEPS:"
echo "1. Verify that this restore script has been executed on ALL cluster nodes"
echo "2. Once ALL nodes are restored, start the containers on ALL nodes"
echo "3. Verify cluster health after all nodes are running"
echo ""
echo "To start this node's container:"
echo "  cd {{ service_dir }} && ./start.sh"
echo ""
echo "To verify cluster health (after all nodes are started):"
echo "  docker exec ${CONTAINER_NAME} etcdctl member list"
echo "  docker exec ${CONTAINER_NAME} etcdctl endpoint health"
