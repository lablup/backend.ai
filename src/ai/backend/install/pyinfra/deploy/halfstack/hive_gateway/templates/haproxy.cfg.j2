global
  maxconn 10000
  log stdout format raw local0 warning

defaults
  mode http
  log global
  option httplog
  option http-server-close
  option dontlognull
  retries 3
  backlog 5000
  timeout client          60s
  timeout connect          5s
  timeout server          60s
  timeout tunnel        3600s   # WebSocket support
  timeout http-keep-alive 60s
  timeout http-request    15s
  timeout queue           30s
  default-server inter 3s rise 2 fall 3
  option forwardfor

frontend stats
  bind *:7999
  stats enable
  stats uri /stats
  stats refresh 10s
  stats admin if LOCALHOST

# GraphQL Federation Gateway
frontend fe_hive_gateway
  bind *:4000
  default_backend be_hive_gateway

backend be_hive_gateway
  balance roundrobin
  http-request set-header X-Forwarded-Port %[dst_port]
  option httpchk
  http-check send meth GET uri /healthcheck
  http-check expect status 200
{%- for node in cluster_nodes %}
  server {{ node.name }} {{ node.ip }}:{{ gateway_port }} weight 1 check
{%- endfor %}
  http-response set-header X-Hive-Gateway-Node %[srv_name]
