#
# [logging.graylog]
# protocol = "tcp"
# ssl_enabled = true
# ssl_verify = true
#
# [logging.graylog.endpoint]
# host = "127.0.0.1"
# port = 8001

[debug]
enabled = false
asyncio = false
enhanced_aiomonitor_task_info = false
log_events = false
