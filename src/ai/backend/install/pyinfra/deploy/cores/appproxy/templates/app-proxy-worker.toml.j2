# ca_certs = "/etc/ssl/ca.pem"
# keyfile = "/etc/backend.ai/graylog/privkey.pem"
# certfile = "/etc/backend.ai/graylog/cert.pem"

[debug]
enabled = false
asyncio = false
enhanced_aiomonitor_task_info = false
log_events = false
