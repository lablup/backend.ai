#!/bin/bash
# Automated diff script for comparing old vs new configurations
# Generated during agent update

set -e

UPGRADE_DIR="{{ upgrade_dir }}"
SERVICE_DIR="{{ service_dir }}"
HOME_DIR="{{ home_dir }}"
BIN_DIR="bin"
CONFIG_DIR=".config/backend.ai"
SERVICE_NAME="{{ service_name }}"

echo "==================================================================="
echo "Agent Configuration Diff Report"
echo "==================================================================="
echo ""

# Function to show diff with header
show_diff() {
    local old_file="$1"
    local new_file="$2"
    local description="$3"

    echo "-------------------------------------------------------------------"
    echo "$description"
    echo "-------------------------------------------------------------------"

    if [ ! -f "$old_file" ]; then
        echo "  ⚠️  Original file not found: $old_file"
        echo "  ✓  New file available at: $new_file"
        echo ""
        return
    fi

    if diff -q "$old_file" "$new_file" > /dev/null 2>&1; then
        echo "  ✓ No changes"
        echo ""
        return
    fi

    echo "  📝 Changes detected:"
    echo ""
    diff -u "$old_file" "$new_file" || true
    echo ""
}

# Compare each file
show_diff "$HOME_DIR/$CONFIG_DIR/$SERVICE_NAME.toml" \
          "$UPGRADE_DIR/$SERVICE_NAME.toml" \
          "agent.toml"

show_diff "$HOME_DIR/$BIN_DIR/run-$SERVICE_NAME.sh" \
          "$UPGRADE_DIR/run-$SERVICE_NAME.sh" \
          "run-agent.sh"

show_diff "$HOME_DIR/$BIN_DIR/run-watcher.sh" \
          "$UPGRADE_DIR/run-watcher.sh" \
          "run-watcher.sh"

show_diff "$SERVICE_DIR/agent-docker-container-opts.json" \
          "$UPGRADE_DIR/agent-docker-container-opts.json" \
          "agent-docker-container-opts.json"

show_diff "/etc/systemd/system/backendai-$SERVICE_NAME.service" \
          "$UPGRADE_DIR/backendai-$SERVICE_NAME.service" \
          "systemd service (agent)"

show_diff "/etc/systemd/system/backendai-watcher.service" \
          "$UPGRADE_DIR/backendai-watcher.service" \
          "systemd service (watcher)"

for script in start stop status show_status; do
    show_diff "$SERVICE_DIR/${script}.sh" \
              "$UPGRADE_DIR/${script}.sh" \
              "${script}.sh"
done

echo "==================================================================="
echo "Summary"
echo "==================================================================="
echo ""
echo "Next steps:"
echo "1. Review the diffs above carefully"
echo "2. Manually merge necessary changes to production configs"
echo "3. Pay special attention to:"
echo "   - ETCD and Redis endpoints"
echo "   - Resource group configuration"
echo "   - Network settings (RPC listen/advertised IPs)"
echo "   - Container port ranges"
echo "   - Scratch storage settings"
echo "   - Custom overrides you may have made"
echo "4. Test after changes:"
echo "   - systemctl restart backendai-watcher"
echo "   - systemctl restart backendai-agent"
echo "5. Monitor logs:"
echo "   - journalctl -u backendai-watcher -f"
echo "   - journalctl -u backendai-agent -f"
echo ""
echo "==================================================================="
