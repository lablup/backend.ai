#!/bin/bash
# Automated diff script for comparing old vs new configurations
# Generated during client update

set -e

UPGRADE_DIR="{{ upgrade_dir }}"
SERVICE_DIR="{{ service_dir }}"

echo "==================================================================="
echo "Configuration Diff Report"
echo "==================================================================="
echo ""

# Function to show diff with header
show_diff() {
    local old_file="$1"
    local new_file="$2"
    local description="$3"

    echo "-------------------------------------------------------------------"
    echo "$description"
    echo "-------------------------------------------------------------------"

    if [ ! -f "$old_file" ]; then
        echo "  ⚠️  Original file not found: $old_file"
        echo "  ✓  New file available at: $new_file"
        echo ""
        return
    fi

    if diff -q "$old_file" "$new_file" > /dev/null 2>&1; then
        echo "  ✓ No changes"
        echo ""
        return
    fi

    echo "  📝 Changes detected:"
    echo ""
    diff -u "$old_file" "$new_file" || true
    echo ""
}

# Compare each file
show_diff "$SERVICE_DIR/.env" \
          "$UPGRADE_DIR/.env" \
          ".env"

show_diff "$SERVICE_DIR/create_session.sh" \
          "$UPGRADE_DIR/create_session.sh" \
          "create_session.sh"

show_diff "$SERVICE_DIR/rescan_images.sh" \
          "$UPGRADE_DIR/rescan_images.sh" \
          "rescan_images.sh"

echo "==================================================================="
echo "Summary"
echo "==================================================================="
echo ""
echo "Next steps:"
echo "1. Review the diffs above carefully"
echo "2. Manually merge necessary changes to production configs"
echo "3. Pay special attention to:"
echo "   - Manager API endpoint"
echo "   - Access keys and secret keys"
echo "   - Custom overrides you may have made"
echo "4. Update your environment with new configs if needed"
echo ""
echo "==================================================================="
