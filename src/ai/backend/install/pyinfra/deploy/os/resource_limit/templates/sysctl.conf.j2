fs.file-max=2048000
fs.inotify.max_user_watches=524288
# Maximum number of file descriptors allowed per process (default: 1048576 = 2^20)
# This kernel parameter (fs.nr_open) takes precedence over both
# ulimit -Hn (system hard limit) and LimitNOFILE (systemd service config)
fs.nr_open=16777216
net.core.rmem_max=16777216
net.core.somaxconn=32768
net.core.wmem_max=16777216
net.ipv4.tcp_early_retrans=1
net.ipv4.tcp_fin_timeout=10
net.ipv4.tcp_max_syn_backlog=32768
net.ipv4.tcp_mem=2097152 4194304 6291456
net.ipv4.tcp_slow_start_after_idle=0
net.ipv4.tcp_tw_reuse=1
net.ipv4.tcp_window_scaling=1
net.ipv4.tcp_rmem=4096 262144 16777216
net.ipv4.tcp_wmem=4096 262144 16777216
net.netfilter.nf_conntrack_max=10485760
net.netfilter.nf_conntrack_tcp_timeout_established=432000
net.netfilter.nf_conntrack_tcp_timeout_close_wait=10
net.netfilter.nf_conntrack_tcp_timeout_fin_wait=10
net.netfilter.nf_conntrack_tcp_timeout_time_wait=10
vm.max_map_count = 262144
vm.overcommit_memory=1
{% if resource_limit_type == 'agent' %}
net.ipv4.ip_local_port_range=40000 65000
{% else %}
net.ipv4.ip_local_port_range=20000 65000
{% endif %}
