x-base: &base
  logging:
    driver: "json-file"
    options:
      max-file: "5"
      max-size: "10m"
  restart: unless-stopped
  extra_hosts:
    - "host.docker.internal:host-gateway"

services:
  redis-exporter:
    <<: *base
    image: oliver006/redis_exporter:${REDIS_EXPORTER_IMAGE_TAG}
    container_name: bai-redis-exporter
    ports:
      - "${REDIS_EXPORTER_PORT}:9121"
    volumes:
      - "/etc/hosts:/etc/hosts:ro"
    environment:
      - REDIS_ADDR=redis://${REDIS_HOST}:${REDIS_PORT}
      - REDIS_PASSWORD=${REDIS_PASSWORD:-}
      - REDIS_EXPORTER_IS_SENTINEL=${REDIS_EXPORTER_IS_SENTINEL:-false}
      - REDIS_EXPORTER_CONNECTION_TIMEOUT=${REDIS_EXPORTER_CONNECTION_TIMEOUT:-15s}
      - REDIS_NAMESPACE=${REDIS_NAMESPACE:-redis}
      - REDIS_EXPORTER_LABELS=${REDIS_EXPORTER_LABELS:-}
    command: >
      --include-system-metrics
      --include-config-metrics
      --include-modules-metrics
    # Health check disabled due to minimal container image
    # healthcheck:
    #   test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:9121/metrics"]
    #   interval: 15s
    #   timeout: 5s
    #   retries: 3
    #   start_period: 10s
