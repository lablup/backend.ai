x-base: &base
  logging:
    driver: "json-file"
    options:
      max-file: "5"
      max-size: "10m"
  restart: unless-stopped
  cpu_count: 2
  mem_limit: "4g"
  extra_hosts:
    - "host.docker.internal:host-gateway"

services:
  pyroscope:
    <<: *base
    image: grafana/pyroscope:${PYROSCOPE_IMAGE_TAG}
    container_name: bai-pyroscope
    user: "10001:10001"  # pyroscope user
    ports:
      - "${PYROSCOPE_PORT}:4040"
    volumes:
      - "/etc/hosts:/etc/hosts:ro"
      - "{{ data_dir }}:/var/lib/pyroscope:rw"
    # Health check disabled (minimal container image without wget/curl)
