x-base: &base
  logging:
    driver: "json-file"
    options:
      max-file: "5"
      max-size: "10m"
  restart: unless-stopped
  cpu_count: 2
  mem_limit: "8g"

services:
  prometheus:
    <<: *base
    image: prom/prometheus:${PROMETHEUS_IMAGE_TAG}
    container_name: bai-prometheus
    user: "65534:65534"  # nobody:nogroup
    ports:
      - "${PROMETHEUS_PORT}:9090"
    volumes:
      - "/etc/hosts:/etc/hosts:ro"
      - "./prometheus.yml:/etc/prometheus/prometheus.yml:ro"
      - "./targets.json:/etc/prometheus/targets.json:ro"
      - "{{ data_dir }}:/prometheus"
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time=${RETENTION_DAYS}d"
      - "--web.enable-lifecycle"
    healthcheck:
      test: ["CMD", "promtool", "check", "healthy"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
