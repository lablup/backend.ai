# Redis Exporter Configuration
REDIS_EXPORTER_IMAGE_TAG={{ exporter_image_tag }}
REDIS_EXPORTER_PORT={{ exporter_port }}

# Redis Connection (HAProxy VIP for HA, direct for single-node)
REDIS_HOST={{ redis_host }}
REDIS_PORT={{ redis_port }}
{% if redis_password %}REDIS_PASSWORD={{ redis_password }}{% endif %}

# Standard Redis monitoring (not Sentinel mode)
# Multi-target monitoring is handled by Prometheus configuration