#!/bin/bash

# Loki Health Check Script
# Checks Loki service readiness via HTTP endpoint

set -euo pipefail

# Load configuration from .env
if [[ -f .env ]]; then
    source .env
fi

LOKI_URL="http://localhost:${LOKI_PORT:-3100}"
READY_ENDPOINT="/ready"

echo "=== Loki Service Status ==="
echo

# Check Docker container status
echo "1. Container Status:"
if command -v docker-compose >/dev/null 2>&1; then
    docker-compose ps loki 2>/dev/null || echo "  Container not found or not running"
else
    docker compose ps loki 2>/dev/null || echo "  Container not found or not running"
fi
echo

# Check Loki ready endpoint
echo "2. Ready Endpoint Check:"
if ! command -v curl >/dev/null 2>&1; then
    echo "  ⚠ curl not available, skipping health checks"
    exit 0
fi

response=$(curl -s "${LOKI_URL}${READY_ENDPOINT}" 2>/dev/null || echo "error")

if [[ "$response" == "ready" ]]; then
    echo "  ✓ Loki is ready"
    echo ""
    echo "✓ Loki Status: Healthy"
    exit 0
else
    echo "  ✗ Loki is not ready"
    echo ""
    echo "3. Error Details:"
    echo "  Response: $response"
    echo ""
    echo "4. Container Logs (last 15 lines):"
    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose logs --tail=15 loki 2>/dev/null || echo "  Cannot retrieve logs"
    else
        docker compose logs --tail=15 loki 2>/dev/null || echo "  Cannot retrieve logs"
    fi

    exit 1
fi
